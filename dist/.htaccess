# Advertise UTF-8 in the Content-Type HTTP header (not just the <meta> tag).
AddDefaultCharset utf-8

# SPA routing for the React app on Hostinger (Apache).
# Real files and folders — JS/CSS assets, /api/*.php, /uploads/* — are served
# as-is; every other path falls back to index.html so react-router can handle it.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Canonical host: 301 www -> non-www so the site has a single address and
  # doesn't split ranking signals / trip duplicate-content checks. The canonical
  # tags all use the bare domain, so www must redirect to it.
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # Never rewrite requests that map to an existing file or directory.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Prerendered static routes: serve /about from the build-time about.html when
  # it exists (matching the canonical, no trailing-slash redirect). Falls
  # through to the SPA entry for routes that weren't prerendered.
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^ %{REQUEST_FILENAME}.html [L]

  # Everything else -> SPA entry point.
  RewriteRule ^ index.html [L]
</IfModule>

# Cache policy. Build assets carry a content hash in their filename (so a new
# deploy = new filenames), making them safe to cache forever. index.html must
# never be cached, or visitors keep loading an old build that points at assets
# that no longer exist.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|mjs|css|woff2?|ttf|otf|eot|jpg|jpeg|png|webp|avif|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set X-LiteSpeed-Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

