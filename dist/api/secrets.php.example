<?php
// Genesis Kreations — secrets template.
//
// Copy this file to GC_PERSIST_DIR/secrets.php on the SERVER (the gc-data/
// folder ABOVE the web root — the same place uploads live). It is loaded by
// api/config.php on every request. Never commit the real secrets.php.
//
//   cp secrets.php.example ../../gc-data/secrets.php   (then edit values)
//
// Every constant is optional: config.php falls back to a safe default for any
// you leave out. Payments stay disabled (503) until the PhonePe credentials
// are set.

// Admin password for the /admin dashboard (replaces the default in config.php).
define('GC_ADMIN_PASSWORD', 'change-me');

// --- PhonePe Standard Checkout V2 (OAuth) -----------------------------------
// From the PhonePe Business dashboard (developer settings). Start with the
// UAT/sandbox credential set and GC_PHONEPE_ENV='sandbox'; switch to the
// production set + 'production' after PhonePe approves go-live.
define('GC_PHONEPE_ENV', 'sandbox'); // 'sandbox' | 'production'
define('GC_PHONEPE_CLIENT_ID', '');
define('GC_PHONEPE_CLIENT_SECRET', '');
define('GC_PHONEPE_CLIENT_VERSION', '1');

// Webhook credentials: the username/password YOU set when configuring the
// webhook URL (https://genesiskreationsmedia.com/api/payments/webhook.php)
// in the PhonePe dashboard. webhook.php validates
// Authorization == SHA256("username:password").
define('GC_PHONEPE_WEBHOOK_USER', '');
define('GC_PHONEPE_WEBHOOK_PASS', '');

// Site origin used for post-payment redirect URLs.
define('GC_SITE_ORIGIN', 'https://genesiskreationsmedia.com');

// --- Email notifications (paid registrations) -------------------------------
// Sent when a payment completes: an alert to GC_ADMIN_NOTIFY_EMAIL and a
// confirmation to the attendee. Leave GC_MAIL_FROM empty to disable entirely.
// GC_MAIL_FROM should be a REAL mailbox on this domain (create it in Hostinger
// email) so messages aren't rejected / spam-filtered.
define('GC_MAIL_FROM', 'no-reply@genesiskreationsmedia.com'); // must be on a Resend-verified domain
define('GC_MAIL_FROM_NAME', 'Genesis Kreations');
define('GC_ADMIN_NOTIFY_EMAIL', 'you@genesiskreationsmedia.com'); // where alerts go
// Resend API key (resend.com -> API Keys). With this set, mail sends via
// Resend; without it, falls back to PHP mail().
define('GC_RESEND_API_KEY', 're_xxxxxxxxxxxxxxxxxxxx');
