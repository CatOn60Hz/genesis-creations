# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist-ssr
*.local

# The built site IS committed so Hostinger's Git auto-deploy can serve it
# (Hostinger doesn't run `npm run build`). Point the domain's document root at
# this dist/ folder. Server-generated content under dist/uploads/ stays out of
# git so deploys never carry or wipe user uploads.
dist/uploads/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Throwaway SSR bundle used by scripts/prerender.mjs
.ssr-tmp

# Real secrets live in GC_PERSIST_DIR/secrets.php on the server (outside the
# web root); only secrets.php.example is committed.
secrets.php
