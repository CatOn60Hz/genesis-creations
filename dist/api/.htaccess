# The JSON list endpoints must always be fresh — the GitHub build + LiteSpeed
# page cache would otherwise serve a stale list (e.g. an empty gallery) after
# photos are uploaded. The PHP endpoints also send no-cache headers themselves.
# Image bytes are streamed by media.php with their own long-lived cache headers,
# so we deliberately do NOT force no-store across the whole folder here.
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>

# Let media.php receive /api/media.php/<section>/<file> via PATH_INFO.
AcceptPathInfo On
