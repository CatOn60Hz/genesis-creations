# API responses must always be fresh. LiteSpeed's page cache would otherwise
# store GET responses (e.g. gallery/projector list.php) and keep serving a
# stale/empty list after photos are uploaded.
<IfModule LiteSpeed>
  CacheDisable public /
  RewriteEngine On
  RewriteRule .* - [E=Cache-Control:no-cache]
</IfModule>

<IfModule mod_headers.c>
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header set Pragma "no-cache"
</IfModule>
