# The JSON list endpoints must always be fresh — the GitHub build + LiteSpeed
# page cache would otherwise serve a stale list (e.g. an empty gallery) after
# photos are uploaded. The PHP endpoints also send no-cache headers themselves.
# Image bytes are streamed by media.php with their own long-lived cache headers,
# so we deliberately do NOT force no-store across the whole folder here.
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>

# Let media.php receive /api/media.php/<section>/<file> via PATH_INFO.
AcceptPathInfo On

# PhonePe's webhook authenticates via the Authorization header, which some
# Apache/CGI setups strip from PHP so payments/webhook.php would always see an
# empty header and reject every callback. Pass it through explicitly.
# (LiteSpeed's LSAPI passes it by default; these are guarded no-ops there.)
<IfModule mod_setenvif.c>
  SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP:Authorization} .
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>
